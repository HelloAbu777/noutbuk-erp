# MongoDB Atlas connection string
# mongodb.com/atlas da bepul cluster oching va shu formatda to'ldiring:
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/noutbuk-erp?retryWrites=true&w=majority

# NextAuth secret — ishlab chiqarishda kuchli tasodifiy qiymat ishlatilsin
# Yangi secret generatsiya: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=your-super-secret-key-change-this

# Vercelda deploy qilinsa, bu yerga Vercel domeningizni yozing
# Masalan: https://noutbuk-erp.vercel.app
NEXTAUTH_URL=https://your-domain.vercel.app

# Telegram bot (ixtiyoriy)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
